# Environment Configuration for EkoAI Playwright Tests
#
# HOW TO USE:
#   1. Environment files live in environments/.env.{dev|staging|prod}
#   2. Set TEST_ENV to choose which environment to run against:
#        TEST_ENV=staging npx playwright test
#        npm run test:staging:smoke
#   3. This root .env file is loaded as FALLBACK / local override
#   4. NEVER commit .env or environments/.env.* with real credentials
#
# For CI/CD, inject these as environment variables directly.

# --- Override: select environment (dev | staging | prod) ---
# TEST_ENV=staging

# --- Application URLs (override per-env defaults) ---
# BASE_URL=https://ekoai-console.staging.ekoapp.com
# API_BASE_URL=https://ekoai.staging.ekoapp.com

# --- Authentication (override per-env defaults) ---
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# --- Login method (cognito | basic | sso) ---
# LOGIN_METHOD=cognito
# SSO_PROVIDER_URL=

# --- Safety ---
# Set to true to skip destructive tests (@create, @update, @delete)
# READONLY_MODE=false

# --- Test Configuration ---
# WORKERS=4
# SPRINT_FOLDER=agentic-18.2

# --- TestRail Integration (optional) ---
# TESTRAIL_HOST=https://ekoapp20.testrail.io
# TESTRAIL_EMAIL=
# TESTRAIL_API_KEY=

# --- CI/CD ---
# CI=true
