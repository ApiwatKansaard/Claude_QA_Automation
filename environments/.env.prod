# Production Environment
# CAUTION: Only run smoke tests on production!
# Never run destructive tests (create/update/delete) on prod.

# --- URLs ---
BASE_URL=https://console.ekoai.com
API_BASE_URL=https://api.ekoai.com

# --- Authentication ---
# Set these in root .env or environment variables (not here — this file is committed)
# ADMIN_EMAIL=your-email@example.com
# ADMIN_PASSWORD=your-password

# --- Login Configuration ---
# Production may use SSO; set accordingly
LOGIN_METHOD=cognito
SSO_PROVIDER_URL=

# --- Safety ---
# Set to true to block destructive tests from running
READONLY_MODE=true
