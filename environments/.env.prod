# Production Environment
# CAUTION: Only read-only tests run on production!
# Destructive tests (create/update/delete) are automatically skipped.

# --- URLs ---
BASE_URL=https://ekoai-console.ekoapp.com
API_BASE_URL=https://ekoai.ekoapp.com

# --- Authentication ---
# Set these in root .env or environment variables (not here — this file is committed)
# ADMIN_EMAIL=tanawoot@amitysolutions.com
# ADMIN_PASSWORD=your-password

# --- Login Configuration ---
LOGIN_METHOD=cognito
SSO_PROVIDER_URL=

# --- Safety ---
# READONLY_MODE=true blocks all tests tagged @create, @update, @delete, @destructive
READONLY_MODE=true
