# Development Environment
# Copy to .env.dev and fill in your values

# --- URLs ---
BASE_URL=https://ekoai-console.dev.ekoapp.com
API_BASE_URL=https://ekoai.dev.ekoapp.com

# --- Authentication ---
# Set these in root .env or environment variables (not here — this file is committed)
# ADMIN_EMAIL=your-email@example.com
# ADMIN_PASSWORD=your-password

# --- Login Configuration ---
# Login method: cognito | basic | sso
LOGIN_METHOD=cognito
# For SSO — set the provider URL (leave empty for cognito/basic)
SSO_PROVIDER_URL=
